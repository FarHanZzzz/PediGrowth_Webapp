{
  "name": "pedi-growth",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "npx kill-port 3000 || exit 0",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "node --max-old-space-size=4096 ./node_modules/eslint/bin/eslint.js",
    "type-check": "tsc --noEmit",
    "test": "node --import tsx --test tests/**/*.test.mjs",
    "benchmark:robustness": "node scripts/python_runner.mjs scripts/run_robustness_benchmark.py --output-dir outputs/robustness_benchmark",
    "benchmark:robustness:quick": "node scripts/python_runner.mjs scripts/run_robustness_benchmark.py --quick --subjects 8 --output-dir outputs/robustness_benchmark_quick",
    "gate:robustness": "node scripts/python_runner.mjs scripts/enforce_robustness_gate.py --current outputs/robustness_benchmark/benchmark_summary.json --baseline data/robustness/benchmark_baseline.json --thresholds data/robustness/robustness_gate_thresholds.json --report outputs/robustness_benchmark/gate_report.json",
    "gate:robustness:quick": "node scripts/python_runner.mjs scripts/enforce_robustness_gate.py --current outputs/robustness_benchmark_quick/benchmark_summary.json --baseline data/robustness/benchmark_baseline.json --thresholds data/robustness/robustness_gate_thresholds.json --report outputs/robustness_benchmark_quick/gate_report.json"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@mediapipe/tasks-vision": "^0.10.34",
    "@supabase/ssr": "^0.10.0",
    "@supabase/supabase-js": "^2.101.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "next": "16.2.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.1.2",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "playwright": "^1.59.1",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "typescript": "^5"
  }
}
