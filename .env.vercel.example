# Vercel project environment variables
# Set these in Vercel Project Settings -> Environment Variables

# Backend service URL hosted on AWS (App Runner, ECS, or ALB)
GAIT_PIPELINE_API_URL=https://your-backend-service.awsapprunner.com

# Public app metadata
NEXT_PUBLIC_APP_VERSION=0.1.0
NEXT_PUBLIC_POLICY_VERSION=0.1.0
NEXT_PUBLIC_VALIDATION_MODE=false

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI navigator (optional)
DASHSCOPE_API_KEY=
DASHSCOPE_MODEL=qwen3.6-plus
DASHSCOPE_REGION=ap-southeast-1
DASHSCOPE_API_URL=
DASHSCOPE_OPENAI_COMPATIBLE_URL=
MOCK_AI=false

# Optional insight model
OPENAI_API_KEY=
OPENAI_MODEL=

# Feature flags
NEXT_PUBLIC_ENABLE_VIDEO_RETENTION=false
NEXT_PUBLIC_ENABLE_AI_NAVIGATOR=true
NEXT_PUBLIC_DEMO_MODE=false
