# Include both temporary and custom frontend domains once available.
# Example:
# CORS_ALLOW_ORIGINS=https://pedi-growth-frontend-abcde.ondigitalocean.app,https://app.yourdomain.com
CORS_ALLOW_ORIGINS=https://replace-with-frontend-domain.ondigitalocean.app
