# Pedi-Growth Environment Variables
# Copy to .env.local and fill in values

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI Navigator (OpenAI-compatible)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Application
NEXT_PUBLIC_APP_VERSION=0.1.0
NEXT_PUBLIC_POLICY_VERSION=0.1.0

# Gait Pipeline Backend
GAIT_PIPELINE_API_URL=http://localhost:8000

# Feature Flags
NEXT_PUBLIC_ENABLE_VIDEO_RETENTION=false
NEXT_PUBLIC_ENABLE_AI_NAVIGATOR=true
NEXT_PUBLIC_DEMO_MODE=false

# Policy Overrides (optional)
# AGE_THRESHOLD_MONTHS=24
